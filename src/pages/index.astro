---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const noticias = (await getCollection('noticias', e => !e.data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout title="Inicio" description="news.automalia.ai — Novedades diarias sobre Claude, Claude Code y el ecosistema Anthropic. Curado sin ruido.">

  <section class="hero">
    <div class="hero-label">news.automalia.ai · The Claude Hub</div>
    <h1>Novedades de <em>Claude</em>,<br/>sin ruido.</h1>
    <p class="lead">Lanzamientos, actualizaciones y anuncios de Anthropic filtrados y explicados. Actualizado diariamente.</p>
    <div class="hero-actions">
      <a class="button button-primary" href="/noticias/">Ver noticias</a>
      <a class="button button-secondary" href="/newsletter/">Suscribirse</a>
    </div>
  </section>

  {noticias.length > 0 && (
    <div class="section-header">
      <span class="section-label">Últimas noticias</span>
      <h2>Lo más reciente</h2>
    </div>
    <div class="card-list">
      {noticias.map((post) => (
        <div class="card">
          <div class="card-meta">
            <span class="date">{post.data.pubDate.toLocaleDateString('es-ES', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
            {post.data.tags.slice(0,2).map(t => <span class="tag">{t}</span>)}
          </div>
          <h2><a href={`/noticias/${post.id.replace(/\.md$/, '')}/`}>{post.data.title}</a></h2>
          <p>{post.data.description}</p>
        </div>
      ))}
    </div>
  )}

  {noticias.length === 0 && (
    <p class="lead" style="text-align:center;padding:40px 0;">Próximamente — las primeras noticias.</p>
  )}

</BaseLayout>
